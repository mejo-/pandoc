  "license": "AGPL-3.0-or-later",
  "files": [
	  "js"
  ],
  "scripts": {
    "build": "NODE_ENV=production webpack --config webpack.js",
    "dev": "NODE_ENV=development webpack --progress --config webpack.js",
    "watch": "NODE_ENV=development webpack --progress --watch --config webpack.js",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --ext .js,.vue src cypress",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint --ext .js,.vue src cypress --fix",
    "stylelint": "stylelint css/*.css css/*.scss src/**/*.scss src/*.vue src/**/*.vue",
    "stylelint:fix": "stylelint css/*.css css/*.scss src/**/*.scss src/**/*.vue --fix"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.3.0"
  },
  "dependencies": {
    "@nextcloud/axios": "^2.6.0",
    "@nextcloud/dialogs": "^6.4.2",
    "@nextcloud/router": "^3.1.0",
    "@nextcloud/vue": "^8.39.0",
    "vue": "^2.7.16",
    "vue-material-design-icons": "^5.3.1",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@cypress/browserify-preprocessor": "^3.0.2",
    "@cypress/webpack-preprocessor": "^7.1.0",
    "@nextcloud/babel-config": "^1.3.0",
    "@nextcloud/browserslist-config": "^3.1.2",
    "@nextcloud/e2e-test-server": "^0.4.0",
    "@nextcloud/eslint-config": "^8.4.2",
    "@nextcloud/event-bus": "^3.3.3",
    "@nextcloud/stylelint-config": "^3.2.2",
    "@nextcloud/webpack-vue-config": "^7.0.2",
    "@vitejs/plugin-vue2": "^2.3.4",
    "@vue/tsconfig": "^0.9.1",
    "cypress": "^15.15.0",
    "cypress-vite": "^1.10.0",
    "eslint-plugin-cypress": "^3.6.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vue-loader": "^15.11.1"
  }
}
